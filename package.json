{
  "name": "comunicacao-inclusiva-api",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "docker:dev": "docker compose --profile dev up -d",
    "docker:dev-stop": "docker compose --profile dev stop",
    "docker:dev-build": "docker compose --profile dev build",
    "docker:dev-down": "docker compose --profile dev down -v",
    "docker:prod": "docker compose --profile prod up -d --build",
    "prisma:migrate:dev": "docker exec -it api_dev npx prisma migrate dev",
    "prisma:migrate:prod": "dotenv -e .env.prod -- prisma migrate deploy",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "npx prisma generate && tsc --noEmit && CHOKIDAR_USEPOLLING=true tsx watch src/server.ts",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "packageManager": "yarn@4.12.0"
}
